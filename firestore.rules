rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Permitir acceso solo a usuarios autenticados
    match /projects/{projectId} {
      allow read, write: if request.auth != null;
    }

    match /leadTimes/{leadTimeId} {
      allow read, write: if request.auth != null;
    }
  }
}
